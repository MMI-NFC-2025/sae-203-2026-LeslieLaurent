---
import Logo from '../assets/Logo.svg';
---
<footer class="bg-[#181818] text-white py-12 px-6 font-serif">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
    <div class="md:col-span-3 flex flex-col gap-6">
      <nav class="flex flex-col gap-3 text-lg md:text-xl">
        <a href="/" class="hover:underline">Accueil</a>
        <a href="/festival" class="hover:underline">Le Festival</a>
        <a href="/programation" class="hover:underline">Programmation</a>
        <a href="/scène" class="hover:underline">La Scène</a>
      </nav>
    </div>
    <div class="md:col-span-3 flex flex-col gap-2">
      <h3 class="font-bold text-lg mb-1">Mention Légal</h3>
      <p class="text-base leading-tight">Projet réalisé en 2025 dans le cadre d’un exercice pédagogique au departement MMI de Montbéliard</p>
    </div>
    <div class="md:col-span-3 flex flex-col gap-2">
      <h3 class="font-bold text-lg mb-1">CONTACT</h3>
      <p class="text-base leading-tight">Loddo Enzo<br>Groupe B1<br>enzo.loddo@edu.univ-fcomte.fr</p>
    </div>
    <div class="md:col-span-3 flex flex-col gap-2 items-center md:items-end">
      <img src={Logo.src} alt="Logo" class="w-32 h-32 opacity-40 mb-2" draggable="false" />
      <h3 class="font-bold text-lg mb-2">NOUS SUIVRE</h3>
      <div class="flex gap-4 mt-2">
        <a href="#" aria-label="Instagram">
          <svg class="w-8 h-8" fill="white" viewBox="0 0 24 24"><path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5A4.25 4.25 0 0 0 20.5 16.25v-8.5A4.25 4.25 0 0 0 16.25 3.5zm4.25 3.25a5.25 5.25 0 1 1 0 10.5a5.25 5.25 0 0 1 0-10.5zm0 1.5a3.75 3.75 0 1 0 0 7.5a3.75 3.75 0 0 0 0-7.5zm5.25.75a1 1 0 1 1-2 0a1 1 0 0 1 2 0z"/></svg>
        </a>
        <a href="#" aria-label="Facebook">
          <svg class="w-8 h-8" fill="white" viewBox="0 0 24 24"><path d="M17 2H7a5 5 0 0 0-5 5v10a5 5 0 0 0 5 5h5v-7H9v-3h3V9.5A3.5 3.5 0 0 1 15.5 6H18v3h-2.5A1.5 1.5 0 0 0 14 10.5V12h4l-1 3h-3v7h3a5 5 0 0 0 5-5V7a5 5 0 0 0-5-5z"/></svg>
        </a>
        <a href="#" aria-label="YouTube">
          <svg class="w-8 h-8" fill="white" viewBox="0 0 24 24"><path d="M21.8 8.001a2.75 2.75 0 0 0-1.94-1.94C18.2 6 12 6 12 6s-6.2 0-7.86.06a2.75 2.75 0 0 0-1.94 1.94A28.7 28.7 0 0 0 2 12a28.7 28.7 0 0 0 .2 3.999a2.75 2.75 0 0 0 1.94 1.94C5.8 18 12 18 12 18s6.2 0 7.86-.06a2.75 2.75 0 0 0 1.94-1.94A28.7 28.7 0 0 0 22 12a28.7 28.7 0 0 0-.2-3.999zM10 15.5v-7l6 3.5l-6 3.5z"/></svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg class="w-8 h-8" fill="white" viewBox="0 0 24 24"><path d="M22 5.924c-.793.352-1.645.59-2.54.697a4.48 4.48 0 0 0 1.964-2.47a8.94 8.94 0 0 1-2.828 1.082A4.48 4.48 0 0 0 11.5 9.5c0 .352.04.695.116 1.022A12.74 12.74 0 0 1 3.1 5.15a4.48 4.48 0 0 0 1.39 5.98a4.47 4.47 0 0 1-2.03-.56v.057a4.48 4.48 0 0 0 3.6 4.39a4.5 4.5 0 0 1-2.02.077a4.48 4.48 0 0 0 4.18 3.11A8.98 8.98 0 0 1 2 19.07a12.7 12.7 0 0 0 6.88 2.02c8.26 0 12.78-6.84 12.78-12.78c0-.195-.004-.39-.013-.583A9.1 9.1 0 0 0 24 4.59a8.98 8.98 0 0 1-2.6.715z"/></svg>
