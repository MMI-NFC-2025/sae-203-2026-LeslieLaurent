---
---
<main class="main-content min-h-screen max-w-xl mx-auto px-4 py-12">
  <h1 class="text-3xl md:text-4xl font-bold mb-8 text-center">Formulaire de contact</h1>
  <section class="form-container bg-white rounded-lg shadow p-8">
    <form action="#" method="post" class="space-y-6">
      <div class="form-group flex flex-col">
        <label for="nom" class="mb-1 font-semibold">Votre nom :</label>
        <input type="text" id="nom" placeholder="ex: Jean-Michel" class="border rounded px-3 py-2" />
      </div>
      <div class="form-group flex flex-col">
        <label for="sujet" class="mb-1 font-semibold">Votre sujet :</label>
        <input type="text" id="sujet" class="border rounded px-3 py-2" />
      </div>
      <div class="form-group flex flex-col">
        <label for="email" class="mb-1 font-semibold">Votre e-mail :</label>
        <input type="email" id="email" placeholder="ex:Jean.michel@hotmail.fr" class="border rounded px-3 py-2" />
      </div>
      <div class="form-group flex flex-col">
        <label for="message" class="mb-1 font-semibold">Votre message :</label>
        <textarea id="message" class="border rounded px-3 py-2 min-h-30"></textarea>
      </div>
      <button type="submit" class="btn-submit bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 transition">Envoyer</button>
    </form>
  </section>
</main>
