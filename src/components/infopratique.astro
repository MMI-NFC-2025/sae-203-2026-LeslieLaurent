<main class="main-content min-h-screen max-w-3xl mx-auto px-4 py-12">
  <h1 class="text-3xl md:text-4xl font-bold mb-6 text-center">Infos Pratiques</h1>
  <p class="text-lg text-blue-700 font-semibold mb-8 text-center">Tarifs et billets</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="ticket-card bg-white rounded-lg shadow p-6 flex flex-col justify-between">
      <div class="ticket-info mb-4">
        <h3 class="text-xl font-bold mb-1">Pass 1 jour</h3>
        <p class="text-gray-600">Valable 1 jour : vendredi ou samedi</p>
      </div>
      <div class="ticket-action flex items-center justify-between">
        <span class="price text-2xl font-bold text-blue-600">35€</span>
        <a href="/404.html" class="btn-buy bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">Acheter</a>
      </div>
    </div>
    <div class="ticket-card bg-white rounded-lg shadow p-6 flex flex-col justify-between">
