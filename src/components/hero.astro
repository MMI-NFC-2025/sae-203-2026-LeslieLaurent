---

import heroImage from "../assets/Hero.png";
---



<div class="relative w-full">
	<img
		src={heroImage.src}
		alt="Chorus Symphonia - Hero"
		class="w-full h-[340px] md:h-[420px] lg:h-[520px] object-cover grayscale opacity-50"
		width="1200"
		height="600"
		loading="eager"
		decoding="async"
	/>
	<div class="absolute top-0 left-0 w-full h-full flex flex-col items-center justify-center text-white text-center px-4">
		<p class="hero__date text-base md:text-lg mb-2 tracking-widest font-medium drop-shadow">Du 29 au 30 août 2026</p>
		<h1 class="hero__title text-4xl md:text-6xl font-extrabold mb-2 drop-shadow-lg font-serif tracking-tight">Chorus Symphonia</h1>
		<p class="hero__subtitle italic text-lg md:text-xl mb-2 drop-shadow">"Chorus Symphonia, fais résonner la Franche-Comté."</p>
	</div>
</div>
