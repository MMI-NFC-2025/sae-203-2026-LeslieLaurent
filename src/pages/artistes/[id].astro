---
import { getArtisteById } from '../../lib/pocketbase.js';
const { id } = Astro.params;
const artiste = await getArtisteById(id);
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <Header />
  <main class="min-h-screen w-full bg-black font-serif flex flex-col items-center justify-start pt-0 pb-8 px-4 md:px-0">
    <section class="bg-[#232323] rounded-xl shadow-lg p-8 mt-10 max-w-2xl w-full flex flex-col items-center">
      <h1 class="text-white text-3xl md:text-4xl font-bold mb-4">Artiste</h1>
      <img src={artiste.photoUrl} alt={artiste.nom} class="w-48 h-48 object-cover rounded-full shadow-lg border-4 border-gray-500 bg-white mb-6" />
      <h2 class="text-white text-2xl font-bold mb-2 text-center">{artiste.nom}</h2>
      <p class="text-gray-300 text-lg mb-2 text-center font-semibold">{artiste.role}</p>
      <div class="text-gray-200 rounded-lg p-4 mb-4 w-full">
          <p class="text-white text-base text-center">{artiste.description}</p>
      </div>
      <div class="flex justify-center mt-12">
        <a href="/artistes" class="px-8 py-3 bg-blue-500 text-white rounded-full shadow-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-300 transition text-center font-semibold text-lg w-fit">Retour à la liste</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
