---
import Layout from '../../layouts/Layout.astro';
import { getArtisteById } from '../../lib/pocketbase.js';
const { id } = Astro.params;
let artiste = null;
try {
  artiste = await getArtisteById(id);
} catch (e) {
  return Astro.redirect('/404');
}
if (!artiste) return Astro.redirect('/404');
---

<Layout>
  <main class="min-h-screen w-full bg-black font-serif flex flex-col items-center justify-start pt-0 pb-8 px-4 md:px-0">
    <section class="bg-[#232323] rounded-xl shadow-lg p-8 mt-10 max-w-2xl w-full flex flex-col items-center">
      <h1 class="text-white text-3xl md:text-4xl font-bold mb-4">{artiste.nom}</h1>
      <img src={artiste.photoUrl} alt={artiste.nom} class="w-48 h-48 object-cover rounded-full shadow-lg border-4 border-gray-500 bg-white mb-6" />
      <div class="flex flex-col md:flex-row gap-4 w-full justify-center items-center mb-4">
        <div class="bg-[#181818] rounded-lg px-4 py-2 text-white text-base font-semibold flex-1 text-center">
          <span class="text-gray-400">Date :</span> {artiste.date ? new Date(artiste.date).toLocaleString('fr-FR', { dateStyle: 'long', timeStyle: 'short' }) : '—'}
        </div>
        <div class="bg-[#181818] rounded-lg px-4 py-2 text-white text-base font-semibold flex-1 text-center">
          <span class="text-gray-400">Scène :</span> {artiste.scene || '—'}
        </div>
      </div>
      <div class="text-gray-200 rounded-lg p-4 mb-4 w-full">
        <p class="text-white text-base text-center">{artiste.description}</p>
      </div>
      {artiste.galerie && artiste.galerie.length > 0 && (
        <div class="w-full mt-6">
          <h3 class="text-white text-xl font-bold mb-4 text-center">Galerie photo</h3>
          <div class="flex flex-wrap gap-4 justify-center">
            {artiste.galerie.map((img, idx) => (
              <img src={img} alt={`Photo ${idx+1} de ${artiste.nom}`} class="w-32 h-32 object-cover rounded-lg shadow border-2 border-gray-700 bg-white" />
            ))}
          </div>
        </div>
      )}
      <div class="flex justify-center mt-12">
        <a href="/artistes" class="px-8 py-3 bg-black text-white rounded-full shadow-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-400 transition text-center font-semibold text-lg w-fit">Retour à la liste</a>
      </div>
    </section>
  </main>
</Layout>
