---
import Layout from '../layouts/Layout.astro';
import { getArtistesByDate } from '../lib/pocketbase.js';

const url = new URL(Astro.request.url);
const genre = url.searchParams.get('genre') || '';
const artistes = await getArtistesByDate({ genre });

//
const allArtistes = await getArtistesByDate({});
const genres = Array.from(new Set(allArtistes.map(a => a.genre).filter(Boolean)));

//
const debug = { genre };
---

<Layout title="Artistes">
  <main class="min-h-screen w-full bg-black font-serif flex flex-col items-center justify-start pt-0 pb-8 px-4 md:px-0">
    <h1 class="text-white text-3xl md:text-4xl font-bold mb-8 mt-8">Les Artistes</h1>
    <form method="get" class="flex flex-col md:flex-row gap-4 mb-8 w-full max-w-4xl justify-center items-end">
      <div class="flex flex-col w-full md:w-auto md:flex-row md:items-center gap-1 md:gap-2">
        <label for="genre" class="text-white mb-1 md:mb-0 md:mr-2 whitespace-nowrap">Genre musical :</label>
        <select id="genre" name="genre" class="rounded bg-[#222] text-white px-3 py-2 w-full md:w-auto">
          <option value="">Tous</option>
          {genres.map(g => <option value={g} selected={g === genre}>{g}</option>)}
        </select>
      </div>
      <button type="submit" class="bg-gray-700 text-white px-6 py-2 rounded-lg hover:bg-gray-900 transition md:mb-0 mb-2">Filtrer</button>
    </form>
    {artistes.length === 0 ? (
      <div class="text-white text-xl text-center my-12">Aucun artiste ne correspond à ce filtre.</div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-10 w-full max-w-6xl">
        {artistes.map(artiste => (
          <div class="flex flex-col items-center bg-[#232323] rounded-xl shadow-lg p-6 hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-400 transition h-full">
            <img src={artiste.photoUrl} alt={"Portrait de " + artiste.nom} class="w-32 h-32 object-cover rounded-full shadow mb-4 border-4 border-gray-500 bg-white" />
            <h2 class="text-white text-xl font-bold mb-2 text-center">{artiste.nom}</h2>
            <p class="text-white text-base mb-1 text-center"><span class="font-semibold">Genre :</span> {artiste.genre || '-'}</p>
            <p class="text-white text-base mb-1 text-center"><span class="font-semibold">Date :</span> {artiste.date ? new Date(artiste.date).toLocaleString('fr-FR', { dateStyle: 'long', timeStyle: 'short' }) : ''}</p>
            <p class="text-white text-base mb-1 text-center"><span class="font-semibold">Scène :</span> {artiste.scene}</p>
            <a href={`/artistes/${artiste.id}`} class="mt-2 w-full inline-block px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-400 transition text-center font-semibold" aria-label={`En savoir plus sur ${artiste.nom}`}>En savoir plus</a>
          </div>
        ))}
      </div>
    )}
  </main>
</Layout>

