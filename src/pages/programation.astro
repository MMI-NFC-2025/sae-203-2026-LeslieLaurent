---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Programmation">
  <Header />
  <main class="min-h-screen w-full bg-black font-serif flex flex-col items-center justify-start pt-8 pb-8 px-4 md:px-0">
    <h1 class="text-white text-3xl md:text-4xl font-serif mb-8 text-center uppercase tracking-wide">La programmation</h1>
    <div class="text-white text-lg md:text-xl mb-8 text-center">
      Début : 17h<br />
      Fin : 00h00
    </div>
    <div class="flex flex-col gap-12 w-full max-w-lg">
      <!-- Premier jour -->
      <div>
        <div class="flex flex-col gap-2 text-white text-center">
          <div>Ouverture du Festival - 17h<br /><span class="text-base">Scène 1</span></div>
          <div>Renato Bruson - 19h45<br /><span class="text-base">Scène 2</span></div>
          <div>Marc Lavoine - 21h30<br /><span class="text-base">Scène 1</span></div>
          <div>Marie-Nicole-Lemieux - 22h<br /><span class="text-base">Scène 2</span></div>
          <div>Lea Nucci - 23h<br /><span class="text-base">Scène 1</span></div>
        </div>
      </div>
      <hr class="border-gray-600 my-4" />
      <!-- Deuxième jour -->
      <div>
        <div class="flex flex-col gap-2 text-white text-center">
          <div>Ouverture du festival – 18h<br /><span class="text-base">Scène 2</span></div>
          <div>Khatia Buniatiskivil - 19h30<br /><span class="text-base">Scène 1</span></div>
          <div>Orchestre de Paris - 20h30<br /><span class="text-base">Scène 2</span></div>
          <div>Joe Hisaishi - 21h30<br /><span class="text-base">Scène 2</span></div>
          <div>Philippe Jaroussky- 23h<br /><span class="text-base">Scène 1</span></div>
        </div>
      </div>
    </div>
    <div class="flex justify-center mt-12">
      <a href="#" class="bg-gray-300 text-[#181818] text-2xl font-serif rounded-2xl px-8 py-2 font-semibold shadow hover:bg-gray-400 transition">PROGRAMME EN PDF</a>
    </div>
  </main>
  <Footer />
</Layout>
    <p>Début : <span class="font-semibold">17h</span></p>
    <p>Fin : <span class="font-semibold">00h00</span></p>
  </div>
  <ul class="prog-list mb-8 space-y-4">
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Ouverture du Festival - 17h</h3>
      <p class="text-gray-600">Scène 1</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Renato Bruson - 19h45</h3>
      <p class="text-gray-600">Scène 2</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Marc Lavoine - 21h30</h3>
      <p class="text-gray-600">Scène 1</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Marie-Nicole Lemieux - 22h</h3>
      <p class="text-gray-600">Scène 2</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Lea Nucci - 23h</h3>
      <p class="text-gray-600">Scène 1</p>
    </li>
  </ul>
  <hr class="my-8 border-purple-400">
  <ul class="prog-list mb-8 space-y-4">
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Ouverture du festival - 18h</h3>
      <p class="text-gray-600">Scène 2</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Khatia Buniatishvili - 19h30</h3>
      <p class="text-gray-600">Scène 1</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Orchestre de Paris - 20h30</h3>
      <p class="text-gray-600">Scène 2</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Joe Hisaishi - 21h30</h3>
      <p class="text-gray-600">Scène 2</p>
    </li>
    <li class="prog-item bg-white rounded-lg shadow p-4">
      <h3 class="font-bold text-lg">Philippe Jaroussky - 23h</h3>
      <p class="text-gray-600">Scène 1</p>
    </li>
  </ul>
  <div class="pdf-download flex items-center justify-center gap-2 mt-8">
    <span class="text-purple-600 text-2xl">❖</span>
    <a href="/404.html" class="btn-pdf bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700 transition">PROGRAMME EN PDF</a>
  </div>
</main>
